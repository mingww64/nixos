#
# D-Bus
#

exec --no-startup-id dbus-update-activation-environment --all
exec nm-applet
exec --no-startup-id gnome-keyring-daemon --start --components=pkcs11,secrets,ssh
#
# Notifications
#
bindsym $mod+n exec "makoctl dismiss"
bindsym $mod+Shift+n exec "makoctl dismiss -a"
bindsym $mod+Shift+m exec "makoctl menu dmenu-wl"
# Albert
exec --no-startup-id albert

# clipman
exec wl-paste -t text --watch clipman store --no-persist

# IME
exec --no-startup-id fcitx5 -d

# Bluetooth
exec blueman-applet

# Notification Daemon
exec mako -c $HOME/.base16/mako

# KDE Connect
exec valent

# Polkit
# exec /usr/lib/polkit-kde-authentication-agent-1

# ScreenShot
bindsym Print exec grimshot copy active 
bindsym shift+Print exec grimshot copy window
bindsym ctrl+Print exec grimshot copy area

# Disable acceleration

input type:pointer {
	accel_profile "flat"
}

# Map tablet

input type:tablet_tool map_to_output HDMI-A-1


include /etc/sway/config.d/*
include $HOME/.config/sway/assign_app_def
include $HOME/.base16/sway
include $HOME/.config/sway/theme
