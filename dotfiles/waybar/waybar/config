{
    "layer": "top",
    "position": "top",
    "modules-left": [
        "custom/media",
        "tray",
        "sway/workspaces"
    ],
    "modules-center": [
        "wlr/taskbar"
    ],
    "modules-right": [
        "sway/language",
        "network",
        "custom/ping",
        "battery",
        "pulseaudio",
        "custom/weather",
        "clock",
        "custom/quit"
    ],
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %b %d}",
        "tooltip": false
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "bat": "BAT1",
        "format": "{icon} {capacity}%",
        "format-charging": "яАб {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "яЗл {essid}",
        "format-ethernet": "ґ░ИА {ifname}",
        "format-disconnected": "",
        "tooltip-format-wifi": "{signalStrength}%",
        "max-length": 20
    },
    "custom/ping": {
        "format": "тШН {}",
        "interval": 60,
        "exec": "$HOME/.config/waybar/get_ping.sh"
    },
    "custom/weather": {
        "exec": "curl 'https://wttr.in/?format=1'",
        "interval": 3600
    },
    "custom/media": {
        "format": "{}",
        "interval": 1,
        "exec": "$HOME/.config/waybar/get_media.sh"
    },
    "custom/keyboard": {
        "format": "яДЬ {}",
        "interval": 1,
        "exec": "$HOME/.config/waybar/get_kbdlayout.sh"
    },
    "tray": {
        "spacing": 10
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}яКФ {volume}%",
        "format-muted": "яАж",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАз",
                "яАи"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "custom/quit": {
        "format": "яАС",
        "on-click": "swaynag -f 'Terminus (TTF)'  -t warning -m 'Do you really want to exit sway?' -b 'Yes, exit sway' 'swaymsg exit'"
    },
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "яДа",
            "2": "яЙи",
            "3": "яДб",
            "4": "яЖ╝",
            "5": "яБ╡",
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДС"
        }
    },
    "sway/language": {
        "format": "{}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "Alacritty"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        }
    }
}