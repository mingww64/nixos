        "format-ethernet": "ˇ░łÇ {ifname}",
        "format-disconnected": "",
        "tooltip-format-wifi": "{signalStrength}%",
        "max-length": 20
    },





    "custom/weather": {
        "exec": "$HOME/.config/waybar/check_weather.sh",
        "interval": 3600
    },
    "custom/media": {
        "format": "{}",
