{
    "layer": "top",
    "position": "top",
    "modules-left": ["custom/media","tray", "sway/workspaces"],
    "modules-center":["wlr/taskbar"],
    "modules-right": ["sway/language", "network","custom/ping", "battery", "pulseaudio", "custom/weather", "clock", "custom/quit"],
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %b %d}",
        "tooltip": false
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "bat":"BAT1",
        "format": "{icon} {capacity}%",
        "format-charging": "ˇ░éä {capacity}%",
        "format-plugged": "´çŽ {capacity}%",
